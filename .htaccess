RewriteEngine On
RewriteRule ^launchbuddy/?$ https://launchbuddy.app [R=301,L]

# Leave requests that already have .html in the URI alone (stops .html being stripped or double-rewritten)
RewriteCond %{REQUEST_URI} \.html
RewriteRule ^ - [L]

# Add .html extension when the request has no extension and the .html file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L] 